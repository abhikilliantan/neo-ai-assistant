{
  "name": "neo-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
