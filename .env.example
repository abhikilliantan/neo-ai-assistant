# =========================================================
# Neo AI Assistant — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# =========================================================

# --- runtime ---
NODE_ENV=development
PYTHON_ENV=development
LOG_LEVEL=info

# --- api (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_SECRET_KEY=change-me-in-prod

# --- auth / jwt ---
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_APP_NAME=Neo AI Assistant

# --- postgres + pgvector ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=neo
POSTGRES_USER=neo
POSTGRES_PASSWORD=neo
DATABASE_URL=postgresql+asyncpg://neo:neo@postgres:5432/neo
# Runtime role (NOSUPERUSER NOBYPASSRLS) — RLS-scoped request DB connection.
APP_DATABASE_URL=postgresql+asyncpg://neo_app:neo_app@postgres:5432/neo

# --- redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- n8n ---
N8N_HOST=n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# --- ai / llm providers ---
# AI_PROVIDER selects which chat provider serves POST /api/v1/chat.
# "mock" is the CI/test default and needs no key.
AI_PROVIDER=mock
AI_MAX_TOKENS=1024

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=
GEMINI_API_KEY=

# --- embeddings ---
# "mock" is the CI/test default and needs no key. "voyage" requires VOYAGE_API_KEY.
# Dimension is locked at 1024 to match the pgvector schema for voyage-3.5.
EMBEDDING_PROVIDER=mock
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3.5
EMBEDDING_DIMENSIONS=1024

# --- memory extraction ---
# "mock" is the CI/test default. "llm" reuses the chat provider (no new key).
MEMORY_EXTRACTOR=mock

# --- memory retrieval ---
# Threshold-gated top-K nearest-neighbour retrieval over the user's own memories,
# injected as a system message before each chat turn's provider call. Ephemeral.
MEMORY_RETRIEVAL_ENABLED=true
MEMORY_RETRIEVAL_TOP_K=5
MEMORY_RETRIEVAL_MIN_SIMILARITY=0.7

# --- tools ---
# Kill switch for the tool-use loop. When false, BOTH /chat and /chat/stream
# pass tools=None to the provider — the loop never engages on either path
# (streaming runs the loop too since 6d).
TOOLS_ENABLED=true

# --- workflows (phase 7) ---
# WORKFLOW_CLIENT selects the workflow-execution backend. "mock" is the
# CI/test default and needs no secrets. "n8n" (7c) calls real webhooks and
# requires N8N_BASE_URL + N8N_AUTH_TOKEN below.
WORKFLOW_CLIENT=mock
# Kill switch mirroring TOOLS_ENABLED (route-level gate).
WORKFLOWS_ENABLED=true
# n8n webhook config — read ONLY when WORKFLOW_CLIENT=n8n. The webhook URL is
# derived as N8N_BASE_URL + "/webhook/" + <workflow name>.
N8N_BASE_URL=
# SECRET — real value goes in .env (gitignored), NEVER here and never logged.
N8N_AUTH_TOKEN=
# Hard timeout (seconds) for a webhook call; it runs inside the live stream.
N8N_TIMEOUT_SECONDS=10.0
