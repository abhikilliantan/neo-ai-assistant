# =========================================================
# Neo AI Assistant — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# =========================================================

# --- runtime ---
NODE_ENV=development
PYTHON_ENV=development
LOG_LEVEL=info

# --- api (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
API_SECRET_KEY=change-me-in-prod

# --- web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_APP_NAME=Neo AI Assistant

# --- postgres + pgvector ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=neo
POSTGRES_USER=neo
POSTGRES_PASSWORD=neo
DATABASE_URL=postgresql+asyncpg://neo:neo@postgres:5432/neo

# --- redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- n8n ---
N8N_HOST=n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# --- llm providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
